# Скопируйте в .env и заполните своими значениями:
#   copy .env.example .env

# --- LLM ---
# local = ответ из RAG без внешнего API (по умолчанию для разработки)
# openai | anthropic | yandex | gigachat
LLM_PROVIDER=local

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
GIGACHAT_CREDENTIALS=

# --- База данных ---
# Локально (Windows, без Docker):
DATABASE_URL=sqlite+aiosqlite:///./data/expert17025.db
# Docker / сервер:
# DATABASE_URL=postgresql+asyncpg://expert17025:CHANGE_ME@localhost:5432/expert17025

REDIS_URL=redis://localhost:6379/0

# --- Безопасность ---
# Сгенерируйте длинную случайную строку для продакшена
SECRET_KEY=change-me-in-production-use-long-random-string

# --- Knowledge Engine ---
USE_LOCAL_EMBEDDINGS=true
KNOWLEDGE_RELEVANCE_THRESHOLD=0.75

# --- CORS и Frontend ---
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
